Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Организатор) Тогда
		Организатор = ИмяПользователя();
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Дата = ТекущаяДата();
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	Если НЕ ЗначениеЗаполнено(Комната) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не выбрана переговорная комната";
		Сообщение.Поле = "Комната";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДатаНачала) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не указано время начала";
		Сообщение.Поле = "ДатаНачала";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ДатаОкончания) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не указано время окончания";
		Сообщение.Поле = "ДатаОкончания";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		Если ДатаОкончания <= ДатаНачала Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Время окончания должно быть позже времени начала";
			Сообщение.Поле = "ДатаОкончания";
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	// Проверка пересечения с другими бронями
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Т.Ссылка КАК Ссылка,
	|	Т.ДатаНачала КАК ДатаНачала,
	|	Т.ДатаОкончания КАК ДатаОкончания,
	|	Т.Организатор КАК Организатор
	|ИЗ
	|	Документ.БронированиеПереговорной КАК Т
	|ГДЕ
	|	Т.Комната = &Комната
	|	И Т.Ссылка <> &ТекущийДок
	|	И НЕ Т.ПометкаУдаления
	|	И Т.Проведен
	|	И Т.ДатаНачала < &ДатаОкончания
	|	И Т.ДатаОкончания > &ДатаНачала";

	Запрос.УстановитьПараметр("Комната", Комната);
	Запрос.УстановитьПараметр("ТекущийДок", Ссылка);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	Результат = Запрос.Выполнить();

	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();

		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Выбранное время уже занято! Пересечение с бронью "
			+ Строка(Выборка.Ссылка) + " ("
			+ Формат(Выборка.ДатаНачала, "ДФ='HH:mm'") + " - "
			+ Формат(Выборка.ДатаОкончания, "ДФ='HH:mm'") + ", "
			+ Выборка.Организатор + ")";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры
